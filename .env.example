# Copy to .env and fill in. Loaded automatically via python-dotenv.

# Required for story generation and the steer_advice LLM judge (routed through OpenRouter).
OPENROUTER_API_KEY=

# Required only for the exploratory `scripts/extras/` experiments that use the
# Claude Haiku judges (calm-injection / reverse-instruction / alpaca-preprompt).
ANTHROPIC_API_KEY=

# Hugging Face token for downloading gated models (e.g. google/gemma-2-9b-it,
# meta-llama/*). Set this or run `huggingface-cli login` before extracting vectors.
HF_TOKEN=
